# ----- OS / IDE -----
.vs/
*.suo
*.user
*.userosscache
*.VC.db
*.VC.opendb



# ----- CMake / Build trees -----
/build/
/build*/
/out/
/install/
/cmake-build-*/
CMakeCache.txt
CMakeFiles/
/Testing/
CMakeUserPresets.json

# Keep project files themselves
!CMakeLists.txt
!CMakePresets.json

# ----- Binaries / objects -----
*.exe
*.dll
*.lib
*.exp
*.ilk
*.obj
*.iobj
*.ipdb
*.pdb
*.idb
*.map

# ----- Logs / databases -----
*.log
*.db
*.sqlite
*.mdb

# ----- Qt autogen (usually under build, but belt & suspenders) -----
*_autogen/

# ----- RenderDoc -----
*.rdc

# ----- Large asset types (don�t need on GitHub) -----
assets/**/*.hdr
assets/**/*.exr
assets/**/*.stl
assets/**/*.obj
assets/**/*.ply
assets/**/*.fbx

# Allow a tiny curated set if you want samples
!assets/samples/**
# Keep dir structure if assets/ is otherwise empty
assets/.gitkeep

# Qt Designer autosave files
*.autosave

# Local build convenience script (machine-specific paths)
run_configure.bat

# ----- Phase-A probe artifacts (Pinocchio attempt §M.3a, reverted; verify/ logs) -----
# external/pinocchio = time-boxed Pinocchio clone, decision reverted to the Eigen oracle.
# verify/ = overnight probe logs + selftest PNGs. Both pollute status; keep out of the tree.
external/pinocchio/
verify/

# YCB object meshes (downloaded via scripts/download_ycb.sh; ~117MB, not committed)
assets/ycb/
